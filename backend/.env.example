APP_NAME="Resumos colaborativos"
# local ou development
APP_ENV=local
# Usar o php artisan key:generate para gerar esta APP_KEY
APP_KEY=
# true ou false
APP_DEBUG=true
#url base da aplicação
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

## Conexão do banco de dados
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

## Configurações para integração com o gmail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# email da conta
MAIL_USERNAME=
# senha da conta
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# email da conta novamente
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

## Configurações para integração com o gmail (google cloud)
# Client id oauth Ex.: "abc123.apps.googleusercontent.com"
CLIENT_ID_OAUTH_GOOGLE_CLOUD=
# Client secret oauth Ex.: "DPAOWA-dmoawi0aniwoa"
CLIENT_SECRET_OAUTH_GOOGLE_CLOUD=
# URL de redirecionamento Ex.: "CAMINHO_BACKEND/api/callback" => manter o /api/callback
REDIRECT_URIS_OAUTH_GOOGLE_CLOUD=
# ID do projeto do google cloud
PROJECT_ID_OAUTH_GOOGLE_CLOUD=
# URI oauth Atualmente utilizado: "https://accounts.google.com/o/oauth2/auth"
AUTH_URI_OAUTH_GOOGLE_CLOUD="https://accounts.google.com/o/oauth2/auth"
# URI para o token atualmente: "https://oauth2.googleapis.com/token"
TOKEN_URI_OAUTH_GOOGLE_CLOUD="https://oauth2.googleapis.com/token"
# Auth provider atualmente: "https://www.googleapis.com/oauth2/v1/certs"
AUTH_PROVIDER_OAUTH_GOOGLE_CLOUD="https://www.googleapis.com/oauth2/v1/certs"

# Caminho do frontend Ex http://localhost:5173
FRONTEND_URL=http://localhost:5173